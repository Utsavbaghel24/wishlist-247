{%- comment -%}
  Wishlist App Embed
  - Loads wishlist.js only after status check
  - Does not load wishlist-header.js
{%- endcomment -%}

<script>
  window.wishlistCustomerId = {{ customer.id | json }};
  window.WISHLIST_PAGE_URL = "/pages/wishlist";
  window.WISHLIST_SHOP = {{ shop.permanent_domain | json }};
</script>

<script>
  (function () {
    var PROXY_BASE = "/apps/wishlist";

    function loadScriptOnce(src, key) {
      if (document.querySelector('script[data-wl-key="' + key + '"]')) return;
      var s = document.createElement("script");
      s.src = src;
      s.defer = true;
      s.setAttribute("data-wl-key", key);
      document.head.appendChild(s);
    }

    fetch(PROXY_BASE + "/status?shop=" + encodeURIComponent(window.WISHLIST_SHOP || "") + "&_t=" + Date.now(), {
      credentials: "include",
      headers: {
        Accept: "application/json"
      }
    })
      .then(function (res) {
        if (res.status === 402) return null;
        if (!res.ok) return null;
        return res.json();
      })
      .then(function (data) {
        if (!data || data.ok !== true) return;

        window.__WISHLIST_PAID__ = true;
        document.documentElement.classList.add("wishlist-paid");

        loadScriptOnce({{ 'wishlist.js' | asset_url | json }}, "wishlist-js");
      })
      .catch(function () {
        /* fail closed */
      });
  })();
</script>

{% schema %}
{
  "name": "Wishlist Embed",
  "target": "body",
  "settings": []
}
{% endschema %}