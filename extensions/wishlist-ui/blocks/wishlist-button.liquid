{% comment %}
FINAL CLEAN VERSION
- No wl-nav link
- Only button + floating icon
{% endcomment %}

<style>
.wishlist-ui {
  display: block !important;
}

/* BUTTON */
.wl-btn {
  width: 100%;
  min-height: 58px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16px 22px;
  border: 1.5px solid #000;
  background: #fff;
  color: #000;
  border-radius: 999px;
  cursor: pointer;
  font-size: 16px;
  font-weight: 500;
  transition: all 0.25s ease;
}

.wl-btn:hover {
  background: #000;
  color: #fff;
}

.wl-btn.is-active {
  background: #000;
  color: #fff;
}

/* FLOATING ICON */
.wl-floating-link {
  position: fixed;
  left: 18px;
  bottom: 18px;
  z-index: 99999;

  width: 56px;
  height: 56px;

  border-radius: 14px;
  background: #000;
  color: #fff;

  display: flex;
  align-items: center;
  justify-content: center;

  box-shadow: 0 12px 28px rgba(0,0,0,0.2);
}

.wl-floating-heart {
  font-size: 22px;
  color: #ff2e63;
}

/* COUNT BADGE */
.wl-floating-count {
  position: absolute;
  top: -6px;
  right: -6px;

  min-width: 20px;
  height: 20px;

  padding: 0 5px;
  border-radius: 999px;

  background: #fff;
  color: #000;

  font-size: 11px;
  font-weight: 700;

  display: none;
  align-items: center;
  justify-content: center;
}

.wl-floating-count.wl-show {
  display: flex;
}

/* TOAST */
.wl-toast {
  position: fixed;
  bottom: 80px;
  right: 20px;
  background: #000;
  color: #fff;
  padding: 10px 14px;
  border-radius: 8px;
  opacity: 0;
  transform: translateY(10px);
  transition: 0.3s;
  z-index: 99999;
}

.wl-toast.show {
  opacity: 1;
  transform: translateY(0);
}
</style>

<script>
  window.wishlistCustomerId = {{ customer.id | json }};
  window.WISHLIST_SHOP = {{ shop.permanent_domain | json }};
</script>

<!-- PRODUCT BUTTON -->
<div class="wishlist-ui">
  <button
    class="wl-btn"
    data-wl-toggle
    data-product-id="{{ product.id }}"
    data-variant-id="{{ product.selected_or_first_available_variant.id }}"
  >
    <span data-wl-label>Add to wishlist</span>
  </button>
</div>

<!-- FLOATING ICON -->
<a href="/pages/wishlist" class="wishlist-ui wl-floating-link">
  <span class="wl-floating-heart">❤</span>
  <span class="wl-floating-count" data-wl-count>0</span>
</a>

<!-- LOAD JS -->
<script>
(function(){
  if (!document.querySelector('[data-wl-script]')) {
    var s = document.createElement("script");
    s.src = {{ 'wishlist.js' | asset_url | json }};
    s.defer = true;
    s.setAttribute("data-wl-script","1");
    document.head.appendChild(s);
  }
})();
</script>