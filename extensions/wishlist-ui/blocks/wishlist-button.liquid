{% comment %}
Wishlist Button Block
- Works with assets/wishlist.js
- Floating wishlist icon on bottom right
- Clean premium styling
- No duplicate inline wishlist logic here
{% endcomment %}

<script>
  window.wishlistCustomerId = {{ customer.id | json }};
  window.WISHLIST_SHOP = {{ shop.permanent_domain | json }};
</script>

<div class="wishlist-ui wl-block">
  <button
    type="button"
    class="wl-btn"
    data-wl-toggle
    data-product-id="{{ product.id }}"
    data-variant-id="{{ product.selected_or_first_available_variant.id }}"
    aria-pressed="false"
    aria-label="Add to wishlist"
  >
    <span class="wl-btn-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none">
        <path
          d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5C2 5.42 4.42 3 7.5 3C9.24 3 10.91 3.81 12 5.09C13.09 3.81 14.76 3 16.5 3C19.58 3 22 5.42 22 8.5C22 12.28 18.6 15.36 13.45 20.04L12 21.35Z"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </span>
    <span class="wl-btn-text" data-wl-label>Add to wishlist</span>
  </button>
</div>

<a
  href="/pages/wishlist"
  class="wl-floating-link"
  id="wl-floating-link"
  aria-label="Open wishlist"
>
  <span class="wl-floating-heart" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5C2 5.42 4.42 3 7.5 3C9.24 3 10.91 3.81 12 5.09C13.09 3.81 14.76 3 16.5 3C19.58 3 22 5.42 22 8.5C22 12.28 18.6 15.36 13.45 20.04L12 21.35Z"/>
    </svg>
  </span>
  <span class="wl-floating-count" data-wl-count style="display:none;">0</span>
</a>

<style>
  .wl-block {
    width: 100%;
    margin-top: 18px;
  }

  .wl-btn {
    width: 100%;
    min-height: 58px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 16px 22px;
    border: 1.5px solid #111111;
    background: #ffffff;
    color: #111111;
    border-radius: 999px;
    cursor: pointer;
    font-size: 16px;
    font-weight: 600;
    line-height: 1.2;
    text-align: center;
    transition: all 0.25s ease;
    box-shadow: none;
    appearance: none;
    -webkit-appearance: none;
  }

  .wl-btn:hover {
    background: #111111;
    color: #ffffff;
    transform: translateY(-1px);
  }

  .wl-btn:focus {
    outline: none;
    box-shadow: 0 0 0 4px rgba(17, 17, 17, 0.10);
  }

  .wl-btn.is-active {
    background: #111111;
    color: #ffffff;
    border-color: #111111;
  }

  .wl-btn.wl-loading,
  .wl-btn:disabled {
    opacity: 0.72;
    cursor: not-allowed;
    transform: none;
  }

  .wl-btn-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    flex: 0 0 18px;
  }

  .wl-btn-icon svg {
    width: 18px;
    height: 18px;
    display: block;
  }

  .wl-btn-text {
    display: inline-block;
  }

  .wl-floating-link {
    position: fixed;
    right: 18px;
    bottom: 18px;
    z-index: 99999;
    width: 60px;
    height: 60px;
    border-radius: 18px;
    background: #111111;
    color: #ffffff;
    text-decoration: none;
    display: none;
    align-items: center;
    justify-content: center;
    box-shadow: 0 14px 32px rgba(0, 0, 0, 0.22);
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    overflow: visible;
  }

  .wl-floating-link.wl-show {
    display: flex;
  }

  .wl-floating-link:hover {
    transform: translateY(-3px);
    background: #000000;
    box-shadow: 0 18px 38px rgba(0, 0, 0, 0.26);
    color: #ffffff;
  }

  .wl-floating-heart {
    width: 26px;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ff4d7d;
  }

  .wl-floating-heart svg {
    width: 26px;
    height: 26px;
    display: block;
  }

  .wl-floating-count {
    position: absolute;
    top: -7px;
    right: -7px;
    min-width: 24px;
    height: 24px;
    padding: 0 7px;
    border-radius: 999px;
    background: #ffffff;
    color: #111111;
    font-size: 11px;
    font-weight: 700;
    line-height: 1;
    display: none;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 14px rgba(0, 0, 0, 0.16);
    border: 1px solid rgba(17, 17, 17, 0.08);
  }

  .wl-disabled-ui .wl-btn,
  .wl-btn.wl-disabled {
    opacity: 0.6;
    cursor: not-allowed;
    pointer-events: none;
  }

  @media (max-width: 749px) {
    .wl-btn {
      min-height: 54px;
      padding: 14px 18px;
      font-size: 15px;
      gap: 8px;
    }

    .wl-btn-icon,
    .wl-btn-icon svg {
      width: 17px;
      height: 17px;
    }

    .wl-floating-link {
      right: 14px;
      bottom: 14px;
      width: 56px;
      height: 56px;
      border-radius: 16px;
    }

    .wl-floating-heart,
    .wl-floating-heart svg {
      width: 24px;
      height: 24px;
    }

    .wl-floating-count {
      min-width: 22px;
      height: 22px;
      font-size: 10px;
      top: -6px;
      right: -6px;
    }
  }
</style>

{% schema %}
{
  "name": "Wishlist Button",
  "target": "section",
  "settings": []
}
{% endschema %}