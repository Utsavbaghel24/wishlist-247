{% comment %}
Wishlist Product Button
Uses the main wishlist.js logic already working in your app.
Bottom-left floating icon links to /pages/wishlist
{% endcomment %}

<style>
  .wishlist-ui { display: block !important; }

  html:not(.wishlist-paid) .wishlist-ui {
    opacity: .45;
    pointer-events: none;
    filter: grayscale(1);
  }

  .wl-block {
    width: 100%;
    margin-top: 14px;
  }

  .wl-btn {
    width: 100%;
    min-height: 58px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px 22px;
    border: 1.5px solid #17324d;
    background: #ffffff;
    color: #17324d;
    border-radius: 999px;
    cursor: pointer;
    font-size: 16px;
    font-weight: 500;
    line-height: 1.2;
    text-align: center;
    transition: all 0.25s ease;
    box-shadow: none;
    appearance: none;
    -webkit-appearance: none;
  }

  .wl-btn:hover {
    background: #17324d;
    color: #ffffff;
  }

  .wl-btn.is-active {
    background: #17324d;
    color: #ffffff;
    border-color: #17324d;
  }

  .wl-btn:focus {
    outline: none;
    box-shadow: 0 0 0 3px rgba(23, 50, 77, 0.12);
  }

  .wl-floating-link {
    position: fixed;
    left: 18px;
    bottom: 18px;
    z-index: 99999;
    width: 58px;
    height: 58px;
    border-radius: 14px;
    background: #17324d;
    color: #ffffff;
    text-decoration: none;
    display: none;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.18);
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .wl-floating-link.wl-show {
    display: inline-flex;
  }

  .wl-floating-link:hover {
    transform: translateY(-2px);
    background: #10273d;
    color: #ffffff;
  }

  .wl-floating-heart {
    font-size: 24px;
    line-height: 1;
  }

  .wl-floating-count {
    position: absolute;
    top: -8px;
    right: -8px;
    min-width: 24px;
    height: 24px;
    padding: 0 6px;
    border-radius: 999px;
    background: #a6dc63;
    color: #17324d;
    font-size: 12px;
    font-weight: 700;
    display: none;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.12);
  }

  .wl-floating-count.wl-show {
    display: flex;
  }

  @media (max-width: 749px) {
    .wl-btn {
      min-height: 54px;
      font-size: 15px;
      padding: 14px 18px;
    }

    .wl-floating-link {
      left: 14px;
      bottom: 14px;
    }
  }
</style>

<script>
  window.wishlistCustomerId = {{ customer.id | json }};
</script>

<div
  class="wishlist-ui wl-block"
  data-product-id="{{ product.id }}"
  data-variant-id="{{ product.selected_or_first_available_variant.id }}"
>
  <button
    type="button"
    class="wl-btn"
    data-wl-toggle
    data-product-id="{{ product.id }}"
    data-variant-id="{{ product.selected_or_first_available_variant.id }}"
    aria-pressed="false"
  >
    <span class="wl-text" data-wl-label>Add to wishlist</span>
  </button>
</div>

<a href="/pages/wishlist" class="wishlist-ui wl-floating-link" id="wl-floating-link" aria-label="Open wishlist page">
  <span class="wl-floating-heart">❤</span>
  <span class="wl-floating-count" id="wl-floating-count" data-wl-count>0</span>
</a>

{% comment %}
Load wishlist.js if not already loaded
{% endcomment %}
<script>
  (function(){
    var alreadyLoaded =
      (typeof window.WishlistUI !== "undefined") ||
      document.querySelector('script[data-wl-script="1"]');

    if (!alreadyLoaded) {
      var s = document.createElement("script");
      s.src = {{ 'wishlist.js' | asset_url | json }};
      s.defer = true;
      s.setAttribute("data-wl-script", "1");
      document.head.appendChild(s);
    }

    function updateFloatingIcon() {
      var countEl = document.getElementById("wl-floating-count");
      var linkEl = document.getElementById("wl-floating-link");
      if (!countEl || !linkEl) return;

      var count = parseInt(countEl.textContent || "0", 10) || 0;

      if (count > 0) {
        linkEl.classList.add("wl-show");
        countEl.classList.add("wl-show");
      } else {
        linkEl.classList.remove("wl-show");
        countEl.classList.remove("wl-show");
      }
    }

    function syncButtonText() {
      document.querySelectorAll('.wl-btn[data-wl-toggle]').forEach(function(btn) {
        var label = btn.querySelector('[data-wl-label]');
        if (!label) return;

        if (btn.classList.contains('is-active') || btn.getAttribute('aria-pressed') === 'true') {
          label.textContent = 'Wishlisted';
        } else {
          label.textContent = 'Add to wishlist';
        }
      });
    }

    function waitForWishlistAndSync() {
      var tries = 0;

      var timer = setInterval(function() {
        tries++;

        syncButtonText();
        updateFloatingIcon();

        if (window.WishlistUI && typeof window.WishlistUI.sync === 'function') {
          window.WishlistUI.sync().then(function() {
            syncButtonText();
            updateFloatingIcon();
          }).catch(function(){});
        }

        if (tries > 20) {
          clearInterval(timer);
        }
      }, 500);
    }

    document.addEventListener('click', function(e) {
      var btn = e.target.closest('[data-wl-toggle]');
      if (!btn) return;

      setTimeout(function() {
        if (window.WishlistUI && typeof window.WishlistUI.sync === 'function') {
          window.WishlistUI.sync().then(function() {
            syncButtonText();
            updateFloatingIcon();
          }).catch(function(){});
        } else {
          syncButtonText();
          updateFloatingIcon();
        }
      }, 700);
    });

    document.addEventListener('DOMContentLoaded', function() {
      waitForWishlistAndSync();
    });

    if (document.readyState !== 'loading') {
      waitForWishlistAndSync();
    }

    var observer = new MutationObserver(function() {
      updateFloatingIcon();
      syncButtonText();
    });

    window.addEventListener('load', function() {
      var countEl = document.getElementById('wl-floating-count');
      if (countEl) {
        observer.observe(countEl, { childList: true, subtree: true, characterData: true });
      }

      setTimeout(function() {
        syncButtonText();
        updateFloatingIcon();
      }, 1200);
    });
  })();
</script>

