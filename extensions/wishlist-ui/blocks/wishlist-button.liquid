{% comment %}
Wishlist Product Button
Only button + floating icon
No extra wishlist nav text link
{% endcomment %}

<style>
  .wishlist-ui {
    display: block !important;
  }

  .wl-block {
    width: 100%;
    margin-top: 16px;
  }

  .wl-btn {
    width: 100%;
    min-height: 58px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px 22px;
    border: 1.5px solid #000;
    background: #fff;
    color: #000;
    border-radius: 999px;
    cursor: pointer;
    font-size: 16px;
    font-weight: 500;
    text-align: center;
    transition: all 0.25s ease;
    appearance: none;
  }

  .wl-btn:hover {
    background: #000;
    color: #fff;
  }

  .wl-btn.is-active {
    background: #000;
    color: #fff;
    border-color: #000;
  }

  .wl-btn:focus {
    outline: none;
    box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.12);
  }

  .wl-btn.wl-disabled,
  .wl-btn[disabled] {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .wl-disabled-ui {
    opacity: 0.7;
  }

  .wl-floating-link {
    position: fixed;
    left: 18px;
    bottom: 18px;
    z-index: 99999;
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: #000;
    color: #fff;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.2);
    transition: all 0.2s ease;
  }

  .wl-floating-link:hover {
    transform: translateY(-3px);
    background: #111;
  }

  .wl-floating-heart {
    font-size: 22px;
    color: #ff2e63;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  .wl-floating-count {
    position: absolute;
    top: -6px;
    right: -6px;
    min-width: 20px;
    height: 20px;
    padding: 0 5px;
    border-radius: 999px;
    background: #fff;
    color: #000;
    font-size: 11px;
    font-weight: 700;
    display: none;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
    line-height: 1;
  }

  .wl-floating-count.wl-show {
    display: flex;
  }

  .wl-toast {
    position: fixed;
    right: 20px;
    bottom: 20px;
    z-index: 100000;
    background: #111;
    color: #fff;
    padding: 12px 16px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 500;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.3s ease;
    box-shadow: 0 12px 28px rgba(0,0,0,0.18);
  }

  .wl-toast.show {
    opacity: 1;
    transform: translateY(0);
  }

  .wl-toast.is-error {
    background: #c62828;
  }

  @media (max-width: 749px) {
    .wl-btn {
      min-height: 52px;
      font-size: 15px;
      padding: 14px 18px;
    }

    .wl-floating-link {
      left: 14px;
      bottom: 14px;
    }

    .wl-toast {
      right: 14px;
      bottom: 80px;
      max-width: calc(100vw - 28px);
    }
  }
</style>

<script>
  window.wishlistCustomerId = {{ customer.id | json }};
  window.WISHLIST_SHOP = {{ shop.permanent_domain | json }};
</script>

<div
  class="wishlist-ui wl-block"
  data-product-id="{{ product.id }}"
  data-variant-id="{{ product.selected_or_first_available_variant.id }}"
>
  <button
    type="button"
    class="wl-btn"
    data-wl-toggle
    data-product-id="{{ product.id }}"
    data-variant-id="{{ product.selected_or_first_available_variant.id }}"
    aria-pressed="false"
  >
    <span class="wl-text" data-wl-label>Add to wishlist</span>
  </button>
</div>

<a
  href="/pages/wishlist"
  class="wishlist-ui wl-floating-link"
  id="wl-floating-link"
  aria-label="Open wishlist page"
>
  <span class="wl-floating-heart">❤</span>
  <span
    class="wl-floating-count"
    id="wl-floating-count"
    data-wl-count
    style="display:none;"
  >0</span>
</a>

<script>
  (function () {
    function loadScriptOnce() {
      var alreadyLoaded =
        document.querySelector('script[data-wl-script="1"]') ||
        (window.WishlistUI && typeof window.WishlistUI.sync === "function");

      if (alreadyLoaded) return;

      var s = document.createElement("script");
      s.src = {{ 'wishlist.js' | asset_url | json }};
      s.defer = true;
      s.setAttribute("data-wl-script", "1");
      document.head.appendChild(s);
    }

    function runSync() {
      if (window.WishlistUI && typeof window.WishlistUI.sync === "function") {
        window.WishlistUI.sync().catch(function (err) {
          console.error("Wishlist sync failed", err);
        });
      }
    }

    loadScriptOnce();

    document.addEventListener("DOMContentLoaded", function () {
      setTimeout(runSync, 300);
    });

    window.addEventListener("load", function () {
      setTimeout(runSync, 400);
    });

    document.addEventListener("wishlist:count-updated", function (e) {
      var count = e.detail && typeof e.detail.count !== "undefined"
        ? Number(e.detail.count || 0)
        : 0;

      var countEls = document.querySelectorAll("[data-wl-count]");
      if (!countEls.length) return;

      countEls.forEach(function (countEl) {
        countEl.textContent = String(count);

        if (count > 0) {
          countEl.classList.add("wl-show");
          countEl.style.display = "flex";
        } else {
          countEl.classList.remove("wl-show");
          countEl.style.display = "none";
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Wishlist Button",
  "target": "section",
  "settings": []
}
{% endschema %}