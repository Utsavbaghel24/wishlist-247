{% comment %}
Wishlist Product Button
Premium UI version
Functionality unchanged
{% endcomment %}

<style>
  .wishlist-ui {
    display: block !important;
  }

  .wl-block {
    width: 100%;
    margin-top: 16px;
  }

  .wl-btn {
    width: 100%;
    min-height: 58px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 16px 22px;
    border: 1.5px solid #111;
    background: #fff;
    color: #111;
    border-radius: 999px;
    cursor: pointer;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.01em;
    text-align: center;
    transition:
      background 0.25s ease,
      color 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      transform 0.2s ease;
    appearance: none;
    -webkit-appearance: none;
  }

  .wl-btn:hover {
    background: #111;
    color: #fff;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.12);
  }

  .wl-btn:active {
    transform: translateY(1px);
  }

  .wl-btn.is-active {
    background: linear-gradient(135deg, #111 0%, #1d1d1d 100%);
    color: #fff;
    border-color: #111;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.16);
  }

  .wl-btn:focus {
    outline: none;
    box-shadow: 0 0 0 3px rgba(17, 17, 17, 0.1);
  }

  .wl-btn.wl-disabled,
  .wl-btn[disabled] {
    opacity: 0.65;
    cursor: not-allowed;
    box-shadow: none;
  }

  .wl-disabled-ui {
    opacity: 0.75;
  }

  .wl-text {
    line-height: 1;
  }

  /* Floating Wishlist Button */
  .wl-floating-link {
    position: fixed;
    left: 20px;
    bottom: 20px;
    z-index: 99999;
    width: 66px;
    height: 66px;
    border-radius: 20px;
    background: linear-gradient(180deg, #111 0%, #050505 100%);
    color: #fff;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow:
      0 16px 36px rgba(0, 0, 0, 0.22),
      0 4px 10px rgba(0, 0, 0, 0.12);
    transition:
      transform 0.22s ease,
      box-shadow 0.22s ease,
      background 0.22s ease;
    overflow: visible;
  }

  .wl-floating-link:hover {
    transform: translateY(-4px);
    background: linear-gradient(180deg, #171717 0%, #080808 100%);
    box-shadow:
      0 20px 42px rgba(0, 0, 0, 0.24),
      0 6px 14px rgba(0, 0, 0, 0.14);
  }

  .wl-floating-link:focus {
    outline: none;
    box-shadow:
      0 0 0 4px rgba(255, 255, 255, 0.68),
      0 16px 36px rgba(0, 0, 0, 0.22);
  }

  .wl-floating-icon-wrap {
    width: 100%;
    height: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .wl-floating-heart {
    font-size: 24px;
    line-height: 1;
    color: #ff4f87;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transform: translateY(1px);
    text-shadow: 0 4px 12px rgba(255, 79, 135, 0.25);
    transition: transform 0.22s ease, color 0.22s ease;
  }

  .wl-floating-link:hover .wl-floating-heart {
    transform: translateY(1px) scale(1.08);
    color: #ff5f95;
  }

  .wl-floating-count {
    position: absolute;
    top: -6px;
    right: -6px;
    min-width: 24px;
    height: 24px;
    padding: 0 6px;
    border-radius: 999px;
    background: #fff;
    color: #111;
    font-size: 11px;
    font-weight: 700;
    display: none;
    align-items: center;
    justify-content: center;
    line-height: 1;
    border: 1px solid rgba(17, 17, 17, 0.06);
    box-shadow:
      0 10px 20px rgba(0, 0, 0, 0.16),
      0 2px 6px rgba(0, 0, 0, 0.08);
  }

  .wl-floating-count.wl-show {
    display: inline-flex;
  }

  /* Toast */
  .wl-toast {
    position: fixed;
    right: 20px;
    bottom: 20px;
    z-index: 100000;
    background: rgba(17, 17, 17, 0.96);
    color: #fff;
    padding: 13px 16px;
    border-radius: 14px;
    font-size: 14px;
    font-weight: 500;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.3s ease;
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.18);
  }

  .wl-toast.show {
    opacity: 1;
    transform: translateY(0);
  }

  .wl-toast.is-error {
    background: rgba(186, 36, 36, 0.96);
  }

  @media (max-width: 749px) {
    .wl-btn {
      min-height: 52px;
      font-size: 15px;
      padding: 14px 18px;
    }

    .wl-floating-link {
      left: 14px;
      bottom: 14px;
      width: 60px;
      height: 60px;
      border-radius: 18px;
    }

    .wl-floating-heart {
      font-size: 22px;
    }

    .wl-floating-count {
      min-width: 22px;
      height: 22px;
      font-size: 10px;
      top: -5px;
      right: -5px;
    }

    .wl-toast {
      right: 14px;
      bottom: 84px;
      max-width: calc(100vw - 28px);
    }
  }
</style>

{{ 'fontawesome-local.css' | asset_url | stylesheet_tag }}

<script>
  window.wishlistCustomerId = {{ customer.id | json }};
  window.WISHLIST_SHOP = {{ shop.permanent_domain | json }};
</script>

<div
  class="wishlist-ui wl-block"
  data-product-id="{{ product.id }}"
  data-variant-id="{{ product.selected_or_first_available_variant.id }}"
>
  <button
    type="button"
    class="wl-btn"
    data-wl-toggle
    data-product-id="{{ product.id }}"
    data-variant-id="{{ product.selected_or_first_available_variant.id }}"
    aria-pressed="false"
  >
    <span class="wl-text" data-wl-label>Add to wishlist</span>
  </button>
</div>

<a
  href="/pages/wishlist"
  class="wishlist-ui wl-floating-link"
  id="wl-floating-link"
  aria-label="Open wishlist page"
>
  <span class="wl-floating-icon-wrap">
    <i class="fa-solid fa-heart wl-floating-heart" aria-hidden="true"></i>

    <span
      class="wl-floating-count"
      id="wl-floating-count"
      data-wl-count
      style="display:none;"
    >0</span>
  </span>
</a>

<script>
  (function () {
    function loadScriptOnce() {
      var alreadyLoaded =
        document.querySelector('script[data-wl-script="1"]') ||
        (window.WishlistUI && typeof window.WishlistUI.sync === "function");

      if (alreadyLoaded) return;

      var s = document.createElement("script");
      s.src = {{ 'wishlist.js' | asset_url | json }};
      s.defer = true;
      s.setAttribute("data-wl-script", "1");
      document.head.appendChild(s);
    }

    function runSync() {
      if (window.WishlistUI && typeof window.WishlistUI.sync === "function") {
        window.WishlistUI.sync().catch(function (err) {
          console.error("Wishlist sync failed", err);
        });
      }
    }

    loadScriptOnce();

    document.addEventListener("DOMContentLoaded", function () {
      setTimeout(runSync, 300);
    });

    window.addEventListener("load", function () {
      setTimeout(runSync, 400);
    });

    document.addEventListener("wishlist:count-updated", function (e) {
      var count = e.detail && typeof e.detail.count !== "undefined"
        ? Number(e.detail.count || 0)
        : 0;

      var countEls = document.querySelectorAll("[data-wl-count]");
      if (!countEls.length) return;

      countEls.forEach(function (countEl) {
        countEl.textContent = String(count);

        if (count > 0) {
          countEl.classList.add("wl-show");
          countEl.style.display = "inline-flex";
        } else {
          countEl.classList.remove("wl-show");
          countEl.style.display = "none";
        }
      });
    });
  })();
</script>

